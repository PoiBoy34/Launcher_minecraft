{
  "name": "minecraft-launcher",
  "version": "1.0.0",
  "main": "src/index.js",
  "scripts": {
    "start": "electron .",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder -mwl"
  },
  "dependencies": {
    "axios": "^1.16.1",
    "electron-log": "^5.4.4",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.3.5",
    "minecraft-launcher-core": "^3.18.2",
    "msmc": "^4.1.0",
    "node-fetch": "^2.7.0",
    "tar": "^7.5.15"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.poiboy.launcher",
    "productName": "Cobblemon Launcher",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": "AppImage",
      "category": "Game"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
