{
  "name": "minecraft-launcher",
  "version": "1.1.2",
  "description": "Un launcher custom pour Cobblemon",
  "author": "PoiBoy34",
  "main": "src/index.js",
  "scripts": {
    "start": "/usr/bin/electron .",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder -mwl",
    "publish:linux": "electron-builder --linux --publish always",
    "publish:win": "electron-builder --win --publish always"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "axios": "^1.16.1",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.3.9",
    "extract-zip": "^2.0.1",
    "fs-extra": "^11.3.5",
    "minecraft-launcher-core": "^3.18.2",
    "msmc": "^4.1.0",
    "node-fetch": "^2.7.0",
    "tar": "^7.5.15"
  },
  "devDependencies": {
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.poiboy.launcher",
    "productName": "Cobblemon Launcher",
    "asar": false,
    "directories": {
      "output": "dist"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "PoiBoy34",
        "repo": "Launcher_minecraft"
      }
    ],
    "linux": {
      "target": "AppImage",
      "category": "Game"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    }
  }
}
